# Tip: the studio UI (npm run ui → Settings → API keys) can manage keys for
# you — it writes them into .env and applies them without a restart.
#
# LLM provider — set any key below. OpenRouter remains the automatic first
# choice, then NanoGPT, then direct Anthropic. The UI has an explicit selector;
# for CLI runs force one with LLM_PROVIDER=anthropic|openrouter|nanogpt.
OPENROUTER_API_KEY=
NANOGPT_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=

# Optional per-stage model overrides (defaults per provider in src/config.ts;
# also settable per run via --research-model / --factcheck-model / --writer-model).
# Use the exact model ids returned by the selected provider's live catalog.
RESEARCH_MODEL=
RECOMMEND_MODEL=
FACTCHECK_MODEL=
WRITER_MODEL=

# Voice (--voice). Defaults to ElevenLabs when set, otherwise the active
# NanoGPT gateway or OpenRouter. Force with VOICE_PROVIDER.
VOICE_PROVIDER=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9   # "Daniel" — measured, documentary-adjacent
TTS_MODEL=                                     # blank follows the provider default
TTS_VOICE=                                     # blank follows the selected model default
TTS_SPEED=0.9                                 # 0.5-2.0; ignored by models without speed control
TTS_CHUNK_CHARS=3000                          # sentence-aware chunks prevent long-input truncation
