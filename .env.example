# Tip: the studio UI (npm run ui → Settings → API keys) can manage keys for
# you — it writes them into .env and applies them without a restart.
#
# LLM provider — set one (or both) keys. If OPENROUTER_API_KEY is set, all
# stages route through OpenRouter; otherwise Anthropic is called directly.
# Force a choice when both are set with LLM_PROVIDER=anthropic|openrouter.
OPENROUTER_API_KEY=sk-or-...
ANTHROPIC_API_KEY=
LLM_PROVIDER=

# Optional per-stage model overrides (defaults per provider in src/config.ts;
# also settable per run via --research-model / --factcheck-model / --writer-model).
# Use OpenRouter slugs ("anthropic/claude-haiku-4.5") on OpenRouter,
# bare Anthropic ids ("claude-haiku-4-5-20251001") on the direct path.
RESEARCH_MODEL=
FACTCHECK_MODEL=
WRITER_MODEL=

# Voice (--voice). Defaults to ElevenLabs when its key is set, else OpenRouter
# TTS (works with just the OpenRouter key). Force with VOICE_PROVIDER.
VOICE_PROVIDER=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9   # "Daniel" — measured, documentary-adjacent
TTS_MODEL=openai/gpt-4o-mini-tts-2025-12-15   # OpenRouter TTS model slug
TTS_VOICE=onyx                                # voice name for that model
